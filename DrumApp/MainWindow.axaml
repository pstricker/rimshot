<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DrumApp.Views"
        x:Class="DrumApp.MainWindow"
        Title="DrumApp"
        Width="900" Height="650"
        MinWidth="500" MinHeight="400">

    <DockPanel Margin="8">

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <ComboBox x:Name="DeviceCombo"
                      PlaceholderText="Select MIDI device…"
                      MinWidth="200" />
            <Button x:Name="ConnectButton"
                    Content="Connect"
                    Click="OnConnectClicked" />
            <Button Content="Refresh"
                    Click="OnRefreshClicked" />
            <Separator Width="1" Background="Gray" Margin="4,2" />
            <Button x:Name="PlayButton"  Content="▶" Width="36" Click="OnPlayClicked" />
            <Button x:Name="PauseButton" Content="⏸" Width="36" Click="OnPauseClicked" IsEnabled="False" />
            <Button x:Name="RestartButton" Content="⟳" Width="36" Click="OnRestartClicked" />
            <Separator Width="1" Background="Gray" Margin="4,2" />
            <TextBlock Text="BPM:" VerticalAlignment="Center" Foreground="Gray" />
            <NumericUpDown x:Name="BpmControl"
                           Value="90" Minimum="40" Maximum="200" Increment="5"
                           MinWidth="110"
                           ValueChanged="OnBpmChanged" />
            <TextBlock x:Name="StatusLabel"
                       VerticalAlignment="Center"
                       Text="Not connected"
                       Foreground="Gray"
                       FontSize="12" />
        </StackPanel>

        <!-- Tabs -->
        <TabControl>
            <TabItem Header="Cue View">
                <views:CueView x:Name="TheCueView" />
            </TabItem>
            <TabItem Header="Tempo">
                <views:TempoView x:Name="TheTempoView" />
            </TabItem>
            <TabItem Header="Monitor">
                <DockPanel>
                    <Button DockPanel.Dock="Top"
                            Content="Clear"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,4"
                            Click="OnClearClicked" />
                    <ListBox x:Name="HitLog"
                             FontFamily="Menlo,Consolas,monospace"
                             FontSize="13"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                </DockPanel>
            </TabItem>
        </TabControl>

    </DockPanel>
</Window>
