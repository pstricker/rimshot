<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Rimshot.Views"
        x:Class="Rimshot.MainWindow"
        Title="Rimshot"
        Icon="avares://Rimshot.Core/Assets/icon.png"
        Width="900" Height="650"
        MinWidth="600" MinHeight="400"
        Background="#0A0A0A">

  <Grid>

    <DockPanel>

        <!-- ============================================================
             HEADER BAR
             RIMSHOT wordmark on the left, transport island centered,
             drum-connection state + ABOUT on the right.
             ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="#141414"
                BorderBrush="#FFD700"
                BorderThickness="0,0,0,2"
                Padding="14,8,14,8">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,Auto">

                <TextBlock Grid.Column="0"
                           Text="RIMSHOT"
                           FontFamily="{StaticResource BebasNeue}"
                           FontSize="32"
                           Foreground="#FFD700"
                           VerticalAlignment="Center"/>

                <!-- CENTER: Transport island (PLAY emphasized as primary).
                     Lives in the header so the toolbar below has room to
                     breathe for SONG controls and the TEMPO widget. -->
                <Border Grid.Column="2"
                        Background="#0A0A0A"
                        BorderBrush="#2A2A2A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="6,4"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <Button x:Name="PlayButton"
                                Content="▶  PLAY"
                                Click="OnPlayClicked"
                                Background="#FFD700"
                                BorderBrush="#FFD700"
                                BorderThickness="1"
                                Foreground="#0A0A0A"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Padding="14,4"/>
                        <Button x:Name="PauseButton"
                                Content="⏸"
                                ToolTip.Tip="Pause"
                                Click="OnPauseClicked"
                                IsEnabled="False"
                                Background="Transparent"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                Foreground="#888888"
                                FontSize="13"
                                Padding="9,4"/>
                        <Button x:Name="StopButton"
                                Content="■"
                                ToolTip.Tip="Stop"
                                Click="OnStopClicked"
                                IsEnabled="False"
                                Background="Transparent"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                Foreground="#888888"
                                FontSize="13"
                                Padding="9,4"/>
                        <Button x:Name="RestartButton"
                                Content="↺"
                                ToolTip.Tip="Restart from beginning"
                                Click="OnRestartClicked"
                                Background="Transparent"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                Foreground="#CCCCCC"
                                FontSize="13"
                                Padding="9,4"/>
                    </StackPanel>
                </Border>

                <!-- Disconnected state: prominent CONNECT DRUMS button -->
                <Button Grid.Column="4"
                        x:Name="ConnectDrumsButton"
                        Content="CONNECT DRUMS"
                        Click="OnConnectDrumsClicked"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="#FFD700"
                        BorderThickness="1"
                        Foreground="#FFD700"
                        FontSize="12"
                        Padding="12,5"
                        Margin="0,0,8,0"/>

                <!-- Connected state: green pill + device name + edit icon -->
                <Border Grid.Column="4"
                        x:Name="ConnectedDrumsBadge"
                        IsVisible="False"
                        VerticalAlignment="Center"
                        Background="#0A1A0A"
                        BorderBrush="#4CAF50"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,4,4,4"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8"
                                 Fill="#4CAF50"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectedDeviceLabel"
                                   Text=""
                                   FontSize="12"
                                   Foreground="#4CAF50"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="200"/>
                        <Button Content="✎"
                                Click="OnConnectDrumsClicked"
                                ToolTip.Tip="Change drum device"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Foreground="#4CAF50"
                                Width="22" Height="22"
                                Padding="0"
                                FontSize="13"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="5"
                        Content="ABOUT"
                        Click="OnAboutClicked"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="#444444"
                        BorderThickness="1"
                        Foreground="#888888"
                        FontSize="11"
                        Padding="10,5"/>
            </Grid>
        </Border>

        <!-- ============================================================
             PRIMARY TOOLBAR
             SONG selector + practice toggles on the left, TEMPO widget
             on the right. Transport now lives in the header above.
             ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="#141414"
                BorderBrush="#FFD700"
                BorderThickness="0,1,0,1"
                Padding="12,8,12,8"
                Margin="0,0,0,2">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- LEFT: SONG + practice toggles -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <TextBlock Text="SONG"
                               FontFamily="{StaticResource BebasNeue}"
                               FontSize="13"
                               Foreground="#FFD700"
                               VerticalAlignment="Center"/>
                    <Button x:Name="LibraryButton"
                            Click="OnLibraryButtonClicked"
                            MinWidth="160"
                            MaxWidth="260"
                            HorizontalContentAlignment="Stretch"
                            Background="#0A0A0A"
                            BorderBrush="#444444"
                            BorderThickness="1"
                            Foreground="#FFD700"
                            FontSize="13"
                            Padding="10,4"
                            ToolTip.Tip="Open the song library">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="LibraryButtonLabel"
                                   Grid.Column="0"
                                   Text="Rock Beat"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="▾"
                                   Margin="8,0,0,0"
                                   Foreground="#888888"
                                   VerticalAlignment="Center"/>
                      </Grid>
                    </Button>
                    <CheckBox x:Name="AutoPlayCheck"
                              Content="AUTO PLAY"
                              ToolTip.Tip="Auto-play hits in time with the cues"
                              VerticalAlignment="Center"
                              Foreground="#FFD700"
                              FontSize="11"
                              Margin="8,0,0,0"
                              IsCheckedChanged="OnAutoPlayChanged"/>
                    <CheckBox x:Name="BackingTrackCheck"
                              Content="BACKING TRACK"
                              ToolTip.Tip="Play the song's backing track audio"
                              IsVisible="False"
                              VerticalAlignment="Center"
                              Foreground="#FFD700"
                              FontSize="11"
                              Margin="4,0,0,0"
                              IsCheckedChanged="OnBackingTrackChanged"/>
                </StackPanel>

                <!-- RIGHT: TEMPO widget + song status -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="SongStatusLabel"
                               VerticalAlignment="Center"
                               Foreground="#666666"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="200"/>
                    <Border Background="#0A0A0A"
                            BorderBrush="#FFD700"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,2,6,2">
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <TextBlock Text="TEMPO"
                                       FontFamily="{StaticResource BebasNeue}"
                                       FontSize="11"
                                       Foreground="#888888"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown x:Name="BpmControl"
                                           Value="90" Minimum="40" Maximum="200" Increment="5"
                                           Width="120"
                                           MinHeight="26"
                                           Foreground="#FFD700"
                                           FontSize="14"
                                           BorderThickness="0"
                                           Background="Transparent"
                                           ValueChanged="OnBpmChanged"/>
                            <TextBlock Text="BPM"
                                       FontFamily="{StaticResource BebasNeue}"
                                       FontSize="10"
                                       Foreground="#FFD700"
                                       VerticalAlignment="Center"
                                       Margin="0,0,2,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Song Timeline (loop selection) -->
        <views:SongTimelineView x:Name="TheTimelineView"
                                DockPanel.Dock="Top"
                                Height="120"/>

        <!-- Tabs -->
        <TabControl Background="#0A0A0A">
            <TabItem Header="CUE VIEW">
                <views:CueView x:Name="TheCueView" />
            </TabItem>
            <TabItem Header="TEMPO">
                <views:TempoView x:Name="TheTempoView" />
            </TabItem>
            <TabItem Header="MONITOR">
                <DockPanel>
                    <Button DockPanel.Dock="Top"
                            Content="CLEAR"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,4"
                            Click="OnClearClicked" />
                    <ListBox x:Name="HitLog"
                             FontFamily="Menlo,Consolas,monospace"
                             FontSize="13"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                </DockPanel>
            </TabItem>
        </TabControl>

    </DockPanel>

    <!-- Full-screen Library overlay -->
    <Border x:Name="LibraryOverlay"
            IsVisible="False"
            Background="#0A0A0A">
      <views:LibraryView x:Name="TheLibraryView"/>
    </Border>

  </Grid>
</Window>
