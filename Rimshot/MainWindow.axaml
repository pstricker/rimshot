<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Rimshot.Views"
        x:Class="Rimshot.MainWindow"
        Title="Rimshot"
        Icon="avares://Rimshot.Core/Assets/icon.png"
        Width="900" Height="650"
        MinWidth="600" MinHeight="400"
        Background="#0A0A0A">

    <DockPanel>

        <!-- ============================================================
             HEADER BAR
             RIMSHOT wordmark on the left, drum-connection state in the
             middle (CONNECT DRUMS button → green device label + edit),
             ABOUT (?) on the right.
             ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="#141414"
                BorderBrush="#FFD700"
                BorderThickness="0,0,0,2"
                Padding="14,8,14,8">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">

                <TextBlock Grid.Column="0"
                           Text="RIMSHOT"
                           FontFamily="{StaticResource BebasNeue}"
                           FontSize="36"
                           Foreground="#FFD700"
                           VerticalAlignment="Center"/>

                <!-- Disconnected state: prominent CONNECT DRUMS button -->
                <Button Grid.Column="2"
                        x:Name="ConnectDrumsButton"
                        Content="CONNECT DRUMS"
                        Click="OnConnectDrumsClicked"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="#FFD700"
                        BorderThickness="1"
                        Foreground="#FFD700"
                        FontSize="12"
                        Padding="14,6"
                        Margin="0,0,8,0"/>

                <!-- Connected state: green pill + device name + edit icon -->
                <Border Grid.Column="2"
                        x:Name="ConnectedDrumsBadge"
                        IsVisible="False"
                        VerticalAlignment="Center"
                        Background="#0A1A0A"
                        BorderBrush="#4CAF50"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,4,4,4"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8"
                                 Fill="#4CAF50"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectedDeviceLabel"
                                   Text=""
                                   FontSize="12"
                                   Foreground="#4CAF50"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="240"/>
                        <Button Content="✎"
                                Click="OnConnectDrumsClicked"
                                ToolTip.Tip="Change drum device"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Foreground="#4CAF50"
                                Width="22" Height="22"
                                Padding="0"
                                FontSize="13"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="3"
                        Content="ABOUT"
                        Click="OnAboutClicked"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="#444444"
                        BorderThickness="1"
                        Foreground="#888888"
                        FontSize="11"
                        Padding="10,5"/>
            </Grid>
        </Border>

        <!-- ============================================================
             PRIMARY TOOLBAR
             Three-section spine:
               LEFT  → SONG selector + practice toggles
               CENTER → Transport island (PLAY emphasized as primary)
               RIGHT → TEMPO widget (compact, "designed" feel)
             ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="#141414"
                BorderBrush="#FFD700"
                BorderThickness="0,1,0,1"
                Padding="12,8,12,8"
                Margin="0,0,0,2">
            <Grid ColumnDefinitions="*,Auto,*">

                <!-- LEFT: SONG + practice toggles -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <TextBlock Text="SONG"
                               FontFamily="{StaticResource BebasNeue}"
                               FontSize="13"
                               Foreground="#FFD700"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="SongCombo"
                              MinWidth="140"
                              MaxWidth="240"
                              SelectionChanged="OnSongSelectionChanged"/>
                    <CheckBox x:Name="AutoPlayCheck"
                              Content="AUTO"
                              ToolTip.Tip="Auto-play hits in time with the cues"
                              VerticalAlignment="Center"
                              Foreground="#FFD700"
                              FontSize="11"
                              Margin="6,0,0,0"
                              IsCheckedChanged="OnAutoPlayChanged"/>
                    <CheckBox x:Name="BackingTrackCheck"
                              Content="BACKING"
                              ToolTip.Tip="Play the song's backing track audio"
                              IsVisible="False"
                              VerticalAlignment="Center"
                              Foreground="#FFD700"
                              FontSize="11"
                              Margin="2,0,0,0"
                              IsCheckedChanged="OnBackingTrackChanged"/>
                </StackPanel>

                <!-- CENTER: Transport island
                     Slightly raised pill background gives the trio visual
                     cohesion. PLAY is filled gold (primary CTA), the rest
                     are outline-only. -->
                <Border Grid.Column="1"
                        Background="#0A0A0A"
                        BorderBrush="#2A2A2A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="6,4"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <Button x:Name="PlayButton"
                                Content="▶  PLAY"
                                Click="OnPlayClicked"
                                Background="#FFD700"
                                BorderBrush="#FFD700"
                                BorderThickness="1"
                                Foreground="#0A0A0A"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Padding="18,5"/>
                        <Button x:Name="PauseButton"
                                Content="⏸"
                                ToolTip.Tip="Pause"
                                Click="OnPauseClicked"
                                IsEnabled="False"
                                Background="Transparent"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                Foreground="#888888"
                                FontSize="14"
                                Padding="10,5"/>
                        <Button x:Name="StopButton"
                                Content="■"
                                ToolTip.Tip="Stop"
                                Click="OnStopClicked"
                                IsEnabled="False"
                                Background="Transparent"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                Foreground="#888888"
                                FontSize="14"
                                Padding="10,5"/>
                        <Button x:Name="RestartButton"
                                Content="↺"
                                ToolTip.Tip="Restart from beginning"
                                Click="OnRestartClicked"
                                Background="Transparent"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                Foreground="#CCCCCC"
                                FontSize="14"
                                Padding="10,5"/>
                    </StackPanel>
                </Border>

                <!-- RIGHT: TEMPO widget + song status
                     Compact tempo indicator with stacked label. Status
                     label sits to the left so long song descriptions
                     have somewhere to breathe without crowding BPM. -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="SongStatusLabel"
                               VerticalAlignment="Center"
                               Foreground="#666666"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="180"/>
                    <Border Background="#0A0A0A"
                            BorderBrush="#FFD700"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,2,4,2">
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Center">
                            <TextBlock Text="TEMPO"
                                       FontFamily="{StaticResource BebasNeue}"
                                       FontSize="11"
                                       Foreground="#888888"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown x:Name="BpmControl"
                                           Value="90" Minimum="40" Maximum="200" Increment="5"
                                           Width="92"
                                           MinHeight="26"
                                           Foreground="#FFD700"
                                           FontSize="14"
                                           BorderThickness="0"
                                           Background="Transparent"
                                           ValueChanged="OnBpmChanged"/>
                            <TextBlock Text="BPM"
                                       FontFamily="{StaticResource BebasNeue}"
                                       FontSize="10"
                                       Foreground="#FFD700"
                                       VerticalAlignment="Center"
                                       Margin="0,0,2,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Song Timeline (loop selection) -->
        <views:SongTimelineView x:Name="TheTimelineView"
                                DockPanel.Dock="Top"
                                Height="120"/>

        <!-- Tabs -->
        <TabControl Background="#0A0A0A">
            <TabItem Header="CUE VIEW">
                <views:CueView x:Name="TheCueView" />
            </TabItem>
            <TabItem Header="TEMPO">
                <views:TempoView x:Name="TheTempoView" />
            </TabItem>
            <TabItem Header="MONITOR">
                <DockPanel>
                    <Button DockPanel.Dock="Top"
                            Content="CLEAR"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,4"
                            Click="OnClearClicked" />
                    <ListBox x:Name="HitLog"
                             FontFamily="Menlo,Consolas,monospace"
                             FontSize="13"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                </DockPanel>
            </TabItem>
        </TabControl>

    </DockPanel>
</Window>
