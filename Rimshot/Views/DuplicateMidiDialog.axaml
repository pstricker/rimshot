<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Rimshot.Views.DuplicateMidiDialog"
        Title="Duplicate MIDI"
        Width="440" Height="240"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#0A0A0A">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="24,20,24,20">

        <TextBlock Grid.Row="0"
                   Text="DUPLICATE MIDI"
                   FontFamily="{StaticResource BebasNeue}"
                   FontSize="32"
                   Foreground="#FFD700"
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1"
                   x:Name="SubtitleLabel"
                   Text="This file is already in your library."
                   FontSize="13"
                   Foreground="#888888"
                   HorizontalAlignment="Center"
                   Margin="0,2,0,16"/>

        <StackPanel Grid.Row="2" Spacing="6" VerticalAlignment="Center">
            <TextBlock TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="#CCCCCC"
                       LineHeight="20"
                       Text="Overwriting will remove the existing entry and re-import this file from its current location."/>
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right">
            <Button Content="CANCEL"
                    Click="OnCancelClicked"
                    Width="120"
                    HorizontalContentAlignment="Center"
                    Background="Transparent"
                    BorderBrush="#444444"
                    BorderThickness="1"
                    Foreground="#888888"/>
            <Button Content="OVERWRITE"
                    Click="OnOverwriteClicked"
                    Width="140"
                    HorizontalContentAlignment="Center"
                    Background="Transparent"
                    BorderBrush="#FFD700"
                    BorderThickness="1"
                    Foreground="#FFD700"/>
        </StackPanel>
    </Grid>
</Window>
