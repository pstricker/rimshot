<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Rimshot.Core.Models;assembly=Rimshot.Core"
             xmlns:services="clr-namespace:Rimshot.Services"
             x:Class="Rimshot.Views.LibraryView"
             Background="#0A0A0A">

    <DockPanel>

        <!-- HEADER STRIP -->
        <Border DockPanel.Dock="Top"
                Background="#141414"
                BorderBrush="#FFD700"
                BorderThickness="0,0,0,2"
                Padding="20,10,14,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="RIMSHOT  /  LIBRARY"
                           FontFamily="{StaticResource BebasNeue}"
                           FontSize="22"
                           Foreground="#FFD700"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        x:Name="CloseButton"
                        Content="✕"
                        Click="OnCloseClicked"
                        Background="Transparent"
                        BorderBrush="#444444"
                        BorderThickness="1"
                        Foreground="#CCCCCC"
                        FontSize="14"
                        Width="32" Height="32"
                        Padding="0"
                        ToolTip.Tip="Close library (Esc)"/>
            </Grid>
        </Border>

        <!-- BODY: left nav + right content -->
        <Grid ColumnDefinitions="200,*">

            <!-- LEFT NAV -->
            <Border Grid.Column="0"
                    Background="#0F0F0F"
                    BorderBrush="#1F1F1F"
                    BorderThickness="0,0,1,0">
                <ListBox x:Name="SectionList"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="OnSectionChanged"
                         Padding="0,12,0,0">
                    <ListBoxItem Tag="library" Padding="20,10">
                        <TextBlock Text="MY LIBRARY"
                                   FontFamily="{StaticResource BebasNeue}"
                                   FontSize="15"
                                   Foreground="#CCCCCC"/>
                    </ListBoxItem>
                    <ListBoxItem Tag="builtin" Padding="20,10">
                        <TextBlock Text="BUILT-IN"
                                   FontFamily="{StaticResource BebasNeue}"
                                   FontSize="15"
                                   Foreground="#CCCCCC"/>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <!-- RIGHT PANE -->
            <Grid Grid.Column="1">

                <!-- ===== MY LIBRARY PANE ===== -->
                <Grid x:Name="MyLibraryPane" IsVisible="False" RowDefinitions="Auto,*">

                    <Border Grid.Row="0" Padding="24,18,24,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MY MIDI LIBRARY"
                                           FontFamily="{StaticResource BebasNeue}"
                                           FontSize="20"
                                           Foreground="#FFD700"/>
                                <TextBlock Text="Files you import are stored locally and remembered between sessions."
                                           Foreground="#888888"
                                           FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="AddMidiButton"
                                    Content="+  ADD MIDI…"
                                    Click="OnAddMidiClicked"
                                    Background="#FFD700"
                                    BorderBrush="#FFD700"
                                    Foreground="#0A0A0A"
                                    FontWeight="SemiBold"
                                    FontSize="13"
                                    Padding="14,6"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <ScrollViewer Padding="24,0,24,24">
                            <ItemsControl x:Name="LibraryList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:MidiLibraryEntry">
                                        <Border Margin="0,0,0,8"
                                                Padding="14,12"
                                                Background="#141414"
                                                BorderBrush="#2A2A2A"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid ColumnDefinitions="*,Auto,Auto"
                                                  RowDefinitions="Auto,Auto">
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{Binding DisplayName}"
                                                           FontSize="15"
                                                           Foreground="#FFD700"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="{Binding MetadataLine}"
                                                           Foreground="#888888"
                                                           FontSize="11"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.RowSpan="2" Grid.Column="1"
                                                        Content="LOAD"
                                                        Click="OnLoadEntryClicked"
                                                        Background="Transparent"
                                                        BorderBrush="#FFD700"
                                                        BorderThickness="1"
                                                        Foreground="#FFD700"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Padding="14,6"
                                                        Margin="12,0,8,0"
                                                        VerticalAlignment="Center"/>
                                                <Button Grid.RowSpan="2" Grid.Column="2"
                                                        Content="REMOVE"
                                                        Click="OnRemoveEntryClicked"
                                                        Background="Transparent"
                                                        BorderBrush="#444444"
                                                        BorderThickness="1"
                                                        Foreground="#888888"
                                                        FontSize="11"
                                                        Padding="10,6"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="MyLibraryEmpty"
                                   IsVisible="False"
                                   Text="Your library is empty.&#x0a;Click  +  ADD MIDI to import a file."
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#555555"
                                   FontSize="13"/>
                    </Grid>
                </Grid>

                <!-- ===== BUILT-IN PANE ===== -->
                <Grid x:Name="BuiltInPane" IsVisible="False" RowDefinitions="Auto,*">

                    <Border Grid.Row="0" Padding="24,18,24,12">
                        <StackPanel>
                            <TextBlock Text="BUILT-IN"
                                       FontFamily="{StaticResource BebasNeue}"
                                       FontSize="20"
                                       Foreground="#FFD700"/>
                            <TextBlock Text="Bundled rudiments and grooves. Tap a row to load."
                                       Foreground="#888888"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="24,0,24,24">
                        <ItemsControl x:Name="BuiltInList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="services:BuiltInGroup">
                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="{Binding Title}"
                                                   FontFamily="{StaticResource BebasNeue}"
                                                   FontSize="14"
                                                   Foreground="#888888"
                                                   Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding Songs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:Song">
                                                    <Button Click="OnLoadBuiltInClicked"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch"
                                                            Margin="0,0,0,6"
                                                            Padding="14,10"
                                                            Background="#141414"
                                                            BorderBrush="#2A2A2A"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Name}"
                                                                       FontSize="14"
                                                                       Foreground="#FFD700"
                                                                       HorizontalAlignment="Left"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="▶"
                                                                       Foreground="#888888"
                                                                       FontSize="13"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </Grid>

    </DockPanel>
</UserControl>
